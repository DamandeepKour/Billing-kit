{
  "name": "billing-kit",
  "version": "1.0.0",
  "description": "Invoicing, GST, Stripe payments, refunds, and webhooks for Node.js",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "billing",
    "invoice",
    "gst",
    "stripe",
    "payments",
    "webhooks"
  ],
  "license": "MIT",
  "dependencies": {
    "stripe": "^17.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
